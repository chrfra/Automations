{
  "name": "automations-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "keygen": "node -e \"const{randomBytes}=require('crypto');const{writeFileSync,mkdirSync,existsSync}=require('fs');const dir='data/secrets';if(!existsSync(dir))mkdirSync(dir,{recursive:true});const kp=dir+'/key';if(existsSync(kp)){console.log('Key already exists — skipping');process.exit(0)}writeFileSync(kp,randomBytes(32).toString('hex'));console.log('Key generated at '+kp)\""
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/cors": "^9.0.0",
    "fastify-plugin": "^5.0.0",
    "better-sqlite3": "^11.0.0",
    "@sinclair/typebox": "^0.33.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.0.0",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
